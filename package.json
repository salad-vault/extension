{
  "name": "saladvault-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "build:wasm": "cd src/crypto-wasm && wasm-pack build --target web --out-dir ../../wasm-pkg",
    "package": "npm run build && cd dist && tar -caf ../saladvault-extension.zip ."
  },
  "dependencies": {
    "preact": "^10.25.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.1.38",
    "@types/webextension-polyfill": "^0.12.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
